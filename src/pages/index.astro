---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <!-- Scroll Progress Bar -->
  <div class="fixed top-0 left-0 w-full h-[3px] bg-gradient-to-r from-secondary via-primary to-[#FF9933] z-50 origin-left scale-x-0" id="scroll-progress"></div>

  <div class="flex flex-col min-h-screen bg-navy-950">
    <!-- ETH Migration Complete Banner -->
    <a
      href="https://x.com/CoolCowsLab/status/2069725634658509222?s=20"
      target="_blank"
      rel="noopener noreferrer"
      class="relative z-50 w-full bg-gradient-to-r from-secondary/20 via-secondary/30 to-secondary/20 border-b border-secondary/30 hover:from-secondary/30 hover:via-secondary/40 hover:to-secondary/30 transition-all duration-300 group"
    >
      <div class="container mx-auto px-4 py-2.5">
        <div class="flex items-center justify-center gap-3 text-sm md:text-base">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 text-secondary animate-pulse"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg>
          <span class="text-white font-medium">
            <span class="text-secondary font-bold">MOOZ Migration is Complete!</span>
            <span class="text-navy-200 ml-2">Locked at 1,700 supply on Ethereum. Cool Cows Lab is ready on Sei!</span>
          </span>
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 text-secondary group-hover:translate-x-1 transition-transform"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </div>
      </div>
      <div class="absolute inset-0 bg-gradient-to-r from-transparent via-secondary/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none"></div>
    </a>

    <!-- Header -->
    <header class="sticky top-0 z-40 w-full bg-navy-950/80 backdrop-blur-sm border-b border-navy-800">
      <div class="container mx-auto px-4 flex h-16 items-center justify-between">
        <div class="flex items-center gap-2">
          <img
            src="/images/logo/logo.png"
            alt="MOOZ Logo"
            width="40"
            height="40"
            class="object-contain"
          />
        </div>
        
        <!-- Desktop Navigation - Top Right -->
        <nav class="hidden md:flex items-center gap-6">
          <a href="#lab" class="text-white hover:text-secondary transition-colors font-medium">Cool Cows Lab</a>
          <a href="#roadmap" class="text-white hover:text-secondary transition-colors font-medium">Roadmap</a>
          <a href="#team" class="text-white hover:text-secondary transition-colors font-medium">Team</a>
        </nav>

        <!-- Mobile Menu Button -->
        <button
          id="mobile-menu-btn"
          class="md:hidden p-2 text-white hover:text-secondary transition-colors"
          aria-label="Toggle menu"
        >
          <svg id="menu-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
          <svg id="close-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 hidden"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
        </button>
      </div>

      <!-- Mobile Dropdown Menu -->
      <div id="mobile-menu" class="hidden md:hidden border-t border-navy-800 bg-navy-950/95 backdrop-blur-sm">
        <nav class="container mx-auto px-4 py-4 flex flex-col gap-4">
          <a href="#lab" class="mobile-nav-link text-white hover:text-secondary transition-colors py-2 text-lg">Cool Cows Lab</a>
          <a href="#roadmap" class="mobile-nav-link text-white hover:text-secondary transition-colors py-2 text-lg">Roadmap</a>
          <a href="#team" class="mobile-nav-link text-white hover:text-secondary transition-colors py-2 text-lg">Team</a>
        </nav>
      </div>
    </header>

    <main class="flex-1">
      <!-- Hero Section -->
      <section class="relative py-20 overflow-hidden hero-section">
        <div class="absolute inset-0 z-0 hero-bg">
          <img
            src="/images/bg/hero-bg.png"
            alt="Hero Background"
            class="w-full h-full object-cover opacity-40"
          />
        </div>
        <div class="container mx-auto px-4 relative z-10 flex flex-col items-center text-center">
          <h1 class="text-4xl md:text-6xl font-bold gradient-text mb-6 hero-title flex flex-wrap justify-center gap-x-3 gap-y-1">
            <span class="inline-block overflow-hidden pb-1"><span class="hero-word inline-block">Welcome</span></span>
            <span class="inline-block overflow-hidden pb-1"><span class="hero-word inline-block">to</span></span>
            <span class="inline-block overflow-hidden pb-1"><span class="hero-word inline-block">the</span></span>
            <span class="inline-block overflow-hidden pb-1"><span class="hero-word inline-block">MOOZ</span></span>
            <span class="inline-block overflow-hidden pb-1"><span class="hero-word inline-block">farm</span></span>
          </h1>
          <p class="text-xl md:text-2xl text-navy-300 max-w-3xl mb-10 hero-text">
            Collect unique digital MOOZ cows on Ethereum. MOOZ has successfully migrated to Ethereum with a final locked supply of 1,700 NFTs.
          </p>
          <div class="flex flex-col sm:flex-row justify-center gap-4 hero-cta">
            <a
              href="https://opensea.io/collection/mooznfts"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center bg-gradient-opensea hover:opacity-90 text-white text-lg px-8 py-4 rounded-lg font-medium transition-opacity"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2 h-5 w-5"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/></svg>
              Buy on OpenSea
            </a>
          </div>
        </div>
      </section>

      <!-- Marketplace & Sales Tracker Section -->
      <section id="marketplace" class="py-20 bg-navy-950">
        <div class="container mx-auto px-4">
          <h2 class="text-3xl md:text-4xl font-bold text-center gradient-text mb-12 marketplace-header">Marketplace & Sales</h2>
          <div class="grid md:grid-cols-2 gap-12 items-center">
            <!-- Sales Tracker Column -->
            <div class="flex flex-col items-center md:items-start text-center md:text-left marketplace-tracker">
              <h3 class="text-2xl font-bold text-white mb-6">Track MOOZ Sales on X</h3>
              <div class="relative h-[300px] w-full max-w-sm rounded-xl overflow-hidden mb-6">
                <img
                  src="/images/sales/sales.jpg"
                  alt="MOOZ Sales Tracker Announcement"
                  class="w-full h-full object-contain rounded-xl"
                />
              </div>
              <p class="text-navy-300 mb-4">
                Follow our dedicated X account for real-time updates on MOOZ sales activity!
              </p>
              <a
                href="https://x.com/MOOZSALES"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center border border-navy-700 hover:bg-navy-800 text-white px-5 py-2.5 rounded-lg font-medium transition-colors"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2 h-4 w-4"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg>
                Follow @MOOZSALES
              </a>
            </div>
            <!-- OpenSea Column with Background -->
            <div class="relative flex flex-col items-center md:items-start text-center md:text-left p-8 rounded-xl overflow-hidden min-h-[350px] justify-center bg-cover bg-center marketplace-opensea" style="background-image: url('/images/marketplace/opensea-preview.png');">
              <!-- Overlay for text readability -->
              <div class="absolute inset-0 bg-navy-950/70 z-0 rounded-xl"></div>
              <!-- Content -->
              <div class="relative z-10 flex flex-col items-center md:items-start w-full">
                <img
                  src="/images/marketplace/opensea.svg"
                  alt="OpenSea Logo"
                  width="60"
                  height="60"
                  class="mb-4"
                />
                <h3 class="text-2xl font-bold text-white mb-4">Available on OpenSea</h3>
                <p class="text-navy-300 mb-6">
                  Purchase MOOZ Cows on the official secondary marketplace.
                </p>
                <a
                  href="https://opensea.io/collection/mooznfts"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center justify-center bg-gradient-opensea hover:opacity-90 text-white px-5 py-2.5 rounded-lg font-medium transition-opacity"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2 h-4 w-4"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/></svg>
                  View Listings
                </a>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Cool Cows Lab Section -->
      <section id="lab" class="relative py-20 overflow-hidden bg-navy-900/40">
        <!-- Decorative background glows -->
        <div class="absolute inset-0 z-0 opacity-10">
          <div class="absolute top-10 left-10 w-72 h-72 bg-gradient-opensea rounded-full blur-3xl"></div>
          <div class="absolute bottom-10 right-10 w-96 h-96 bg-gradient-me rounded-full blur-3xl"></div>
        </div>

        <div class="container mx-auto px-4 relative z-10">
          <div class="max-w-4xl mx-auto text-center mb-16">
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-gradient-opensea/10 border border-gradient-opensea/20 text-secondary text-sm font-semibold mb-4 animate-glow lab-badge">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 text-secondary"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg>
              The Next Chapter
            </span>
            <h2 class="text-4xl md:text-5xl font-bold gradient-text mb-6 lab-header">
              Cool Cows Lab is Ready 🧪
            </h2>
            <p class="text-xl text-navy-300 max-w-2xl mx-auto lab-desc">
              THE CYCLE IS HERE. We've built an unbreakable foundation through the bear market and are ready to dominate this cycle on Sei.
            </p>
          </div>

          <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto mb-12">
            <!-- Card 1: The Launchpad -->
            <div class="lab-card">
              <div class="group relative bg-navy-900/60 backdrop-blur-sm rounded-2xl p-8 border border-navy-800 transition-all duration-300 hover:-translate-y-1 hover:border-secondary/30 hover:shadow-[0_10px_30px_rgba(255,153,51,0.1)] h-full">
                <div class="w-12 h-12 rounded-xl bg-gradient-opensea/10 flex items-center justify-center border border-gradient-opensea/20 mb-6 group-hover:scale-110 transition-transform duration-300">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 text-secondary"><path d="M4.5 16.5c-1.5 1.26-2.5 3.19-2.5 5.5s1 4.24 2.5 5.5M19.5 16.5c1.5 1.26 2.5 3.19 2.5 5.5s-1 4.24-2.5 5.5M12 2v20M17 5H7M15 9H9M13 13h-2"/></svg>
                </div>
                <h3 class="text-xl font-bold text-white mb-4">The Launchpad</h3>
                <p class="text-navy-300 leading-relaxed">
                  Our tech is battle-tested and ready to incubate the next tier of Web3 projects. Providing secure infrastructure and support to bring top-tier collections to life on Sei.
                </p>
              </div>
            </div>

            <!-- Card 2: The Tools -->
            <div class="lab-card">
              <div class="group relative bg-navy-900/60 backdrop-blur-sm rounded-2xl p-8 border border-navy-800 transition-all duration-300 hover:-translate-y-1 hover:border-secondary/30 hover:shadow-[0_10px_30px_rgba(255,153,51,0.1)] h-full">
                <div class="w-12 h-12 rounded-xl bg-gradient-opensea/10 flex items-center justify-center border border-gradient-opensea/20 mb-6 group-hover:scale-110 transition-transform duration-300">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 text-secondary"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
                </div>
                <h3 class="text-xl font-bold text-white mb-4">The Tools</h3>
                <p class="text-navy-300 leading-relaxed">
                  No more guessing in the trenches. Our custom analytics and management utilities are dialed in to give the herd the exact edge needed to win this bull cycle.
                </p>
              </div>
            </div>

            <!-- Card 3: The Vaults -->
            <div class="lab-card">
              <div class="group relative bg-navy-900/60 backdrop-blur-sm rounded-2xl p-8 border border-navy-800 transition-all duration-300 hover:-translate-y-1 hover:border-secondary/30 hover:shadow-[0_10px_30px_rgba(255,153,51,0.1)] h-full">
                <div class="w-12 h-12 rounded-xl bg-gradient-opensea/10 flex items-center justify-center border border-gradient-opensea/20 mb-6 group-hover:scale-110 transition-transform duration-300">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 text-secondary"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/><path d="M3 12c0 1.66 4 3 9 3s9-1.34 9-3"/></svg>
                </div>
                <h3 class="text-xl font-bold text-white mb-4">The Vaults</h3>
                <p class="text-navy-300 leading-relaxed">
                  The heartbeat of our ecosystem. Vaults, rewards, and the true utility of the $MOOZ token are ready to run at full speed as part of our core launchpad hub.
                </p>
              </div>
            </div>
          </div>

          <div class="flex justify-center lab-cta">
            <a
              href="https://x.com/MoozNft/status/2004636909180755982?s=20"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center bg-gradient-opensea hover:opacity-90 text-white text-lg px-8 py-4 rounded-xl font-medium transition-opacity"
            >
              Read the Announcement
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-2 h-5 w-5"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg>
            </a>
          </div>
        </div>
      </section>

      <!-- Ecosystem Synergy Section -->
      <section id="synergy" class="relative py-28 overflow-hidden bg-navy-950 border-t border-navy-900">
        <!-- Background image with radial gradient overlay -->
        <div class="absolute inset-0 z-0">
          <img
            src="/images/bg/synergy-bg.jpg"
            alt="The Evolution of the Herd"
            class="w-full h-full object-cover opacity-90"
          />
          <div class="absolute inset-0 bg-gradient-to-b from-navy-950 via-navy-950/20 to-navy-950"></div>
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(255,153,51,0.05),transparent_70%)]"></div>
        </div>

        <div class="w-full max-w-[96%] xl:max-w-[92%] 2xl:max-w-[88%] mx-auto px-4 relative z-10">
          <!-- Title & Intro -->
          <div class="max-w-4xl mx-auto text-center mb-16 synergy-item">
            <h2 class="text-4xl md:text-5xl font-bold gradient-text mb-6">
              The Evolution of the Herd: From Assets to Web3 Infrastructure
            </h2>
            <p class="text-lg md:text-xl text-navy-200 leading-relaxed font-light">
              This is the story of how two interconnected NFT collections evolved from standalone digital assets into the foundational ecosystem powering a comprehensive multi-chain developer hub.
            </p>
          </div>

          <!-- Main Chapters Grid (Leaving center column empty for the cows) -->
          <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 mb-20 items-start">
            <!-- Left Card: Chapter 1: The Origin (MOOZ) -->
            <div class="lg:col-span-4 synergy-left-card">
              <div class="bg-navy-900/80 backdrop-blur-md rounded-3xl p-8 border border-navy-800 shadow-[0_20px_50px_rgba(0,0,0,0.4)] hover:border-secondary/20 transition-all duration-300 group">
                <div class="flex items-center gap-3 mb-6">
                  <div class="w-10 h-10 rounded-full bg-secondary/10 flex items-center justify-center text-secondary border border-secondary/20">
                    <span class="font-bold text-lg">1</span>
                  </div>
                  <h3 class="text-2xl font-bold text-white group-hover:text-secondary transition-colors">
                    Chapter 1: The Origin (MOOZ)
                  </h3>
                </div>
                <div class="space-y-4 text-navy-300 leading-relaxed text-justify text-sm md:text-base">
                  <p>
                    The journey began with <strong class="text-white">MOOZ</strong>, a vibrant community-driven collection originally launched on the Sei network. As a pioneer asset, MOOZ established the core identity of the "herd"—a loyal, highly engaged community of collectors and Web3 enthusiasts.
                  </p>
                  <p>
                    However, scaling a true technological ecosystem required a shift. To unlock higher liquidity, broader market exposure, and advanced smart contract capabilities, the collection executed a massive migration from Sei over to the Ethereum network. This migration successfully bridged the core community to a larger stage, laying the groundwork for what was coming next.
                  </p>
                </div>
              </div>
            </div>

            <!-- Spacer column (Where the cows are visible in the background) -->
            <div class="hidden lg:block lg:col-span-4 h-64 pointer-events-none"></div>

            <!-- Right Card: Chapter 2: The Infrastructure (Cool Cows Lab) -->
            <div class="lg:col-span-4 synergy-right-card">
              <div class="bg-navy-900/80 backdrop-blur-md rounded-3xl p-8 border border-navy-800 shadow-[0_20px_50px_rgba(0,0,0,0.4)] hover:border-secondary/20 transition-all duration-300 group">
                <div class="flex items-center gap-3 mb-6">
                  <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center text-primary border border-primary/20">
                    <span class="font-bold text-lg">2</span>
                  </div>
                  <h3 class="text-2xl font-bold text-white group-hover:text-primary transition-colors">
                    Chapter 2: The Infrastructure
                  </h3>
                </div>
                <div class="space-y-4 text-navy-300 leading-relaxed text-sm md:text-base">
                  <p class="text-justify">
                    With the community firmly anchored on Ethereum, <strong class="text-white">Cool Cows Lab</strong> was introduced as the engineering and utility arm of the ecosystem. It shifted the brand's narrative from "just grazing" to active building, expanding into a powerhouse for full-stack developer services.
                  </p>
                  <div class="pt-2 border-t border-navy-800/60 space-y-3">
                    <h4 class="text-white font-semibold text-sm uppercase tracking-wider">Critical Pillars:</h4>
                    <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-xs md:text-sm">
                      <li class="flex items-start gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="mt-0.5 text-secondary flex-shrink-0"><path d="M20 6 9 17l-5-5"/></svg>
                        <div><strong class="text-white">Multi-Chain Launchpad:</strong> Incubate, deploy, and mint new collections.</div>
                      </li>
                      <li class="flex items-start gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="mt-0.5 text-secondary flex-shrink-0"><path d="M20 6 9 17l-5-5"/></svg>
                        <div><strong class="text-white">Custom Automation:</strong> Advanced trading, tracking, and utility bots.</div>
                      </li>
                      <li class="flex items-start gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="mt-0.5 text-secondary flex-shrink-0"><path d="M20 6 9 17l-5-5"/></svg>
                        <div><strong class="text-white">The Tools:</strong> Custom analytics and contract utilities.</div>
                      </li>
                      <li class="flex items-start gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="mt-0.5 text-secondary flex-shrink-0"><path d="M20 6 9 17l-5-5"/></svg>
                        <div><strong class="text-white">The Vaults:</strong> Secure digital asset rewards and utility.</div>
                      </li>
                    </ul>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Bottom Card: Connection & Summary -->
          <div class="max-w-6xl mx-auto synergy-bottom-card">
            <div class="bg-navy-900/85 backdrop-blur-md rounded-3xl p-8 md:p-12 border border-navy-800 shadow-[0_20px_50px_rgba(0,0,0,0.5)] hover:border-secondary/10 transition-all duration-300">
              <div class="grid lg:grid-cols-12 gap-8 items-start">
                
                <!-- The Connection Details -->
                <div class="lg:col-span-8 space-y-6">
                  <h3 class="text-2xl font-bold text-white flex items-center gap-2">
