---
const milestones = [
  {
    tag: "✅ 10%",
    status: "done",
    title: "Paying Back Our Moms",
    description: "Our OG backers were the ones who made this possible. Mission accomplished! (Shoutout to Gordo & Garga for the reminder back in '21)."
  },
  {
    tag: "✅ 20%",
    status: "done",
    title: "Pasture of Renewal Opens",
    description: "The V1 to V2 transition is complete! The Pasture of Renewal allowed Cool Cows to evolve into MOOZ and their new forms, unlocking fresh designs and perks."
  },
  {
    tag: "✅ 30%",
    status: "done",
    title: "Herd Radio: Your Soundtrack to Adventure",
    description: "The airwaves of Moo-via are alive! Herd Radio is now streaming, bringing music, lore, and community-driven content to every adventurer."
  },
  {
    tag: "🔄 40%",
    status: "progress",
    title: "The Quest Begins – Find the Rare Ones",
    description: "The hunt for legendary 1:1 MOOZ is coming soon! Hidden treasures await those who decipher the clues scattered across Moo-via Commons."
  },
  {
    tag: "🔄 50%",
    status: "progress",
    title: "Moo-via Commons Unveiling",
    description: "The history of Moo-via is being revealed one page at a time! A new page drops every week, unraveling the founding of the kingdom."
  },
  {
    tag: "🔜 60%",
    status: "upcoming",
    title: "Noggles Pasture – Where Legends Graze",
    description: "A special sanctuary for cows with Nouns-inspired traits is opening soon! Exclusive perks await, because being legendary has its benefits."
  },
  {
    tag: "✅ 80%",
    status: "done",
    title: "Vaults Relocation",
    description: "Staking on SEI has been decommissioned. Vaults are being relocated and relaunched soon on Ethereum for $MOOZ utilities."
  },
  {
    tag: "✅ 90%",
    status: "done",
    title: "Paying Our Starving Artists",
    description: "The MOOZ art team (looking at you, @FastFrogStudio) is finally getting their due! No more exposure payments—only well-earned rewards. Mission accomplished!"
  },
  {
    tag: "🎉 BONUS",
    status: "bonus",
    title: "The Creation of @HighlanderDAO",
    description: "One of the coolest things about MOOZ family is seeing community-led initiatives thrive! This grassroots effort by passionate holders is a great example of how the MOOZ ecosystem grows organically. HighlanderDAO empowers the community with governance rights and collaborative decision-making, showcasing the decentralized spirit of the MOOZ family."
  },
  {
    tag: "✅ 100%",
    status: "done",
    title: "Migration Complete",
    description: "The SEI chapter is closed, and the migration to Ethereum is officially complete. Unmigrated NFTs have been removed, locking the final total supply permanently at 1,700 NFTs on Ethereum."
  },
  {
    tag: "🚀 NEXT PHASE",
    status: "next",
    title: "Cool Cows Lab Launch",
    description: "Relaunching tools on Sei as our launchpad, custom analytics, and developer hub. Stay tuned for the Cool Cows Lab updates!"
  }
];
---

<section id="roadmap" class="py-20 bg-navy-900">
  <div class="container mx-auto px-4">
    <h2 class="text-3xl md:text-4xl font-bold text-center gradient-text mb-12 roadmap-header">Mooz Roadmap 1.2</h2>
    <div class="relative max-w-4xl mx-auto" id="roadmap-timeline">
      <!-- Vertical line -->
      <div class="absolute left-[20px] md:left-1/2 transform md:-translate-x-1/2 h-full w-1 bg-navy-800 origin-top overflow-hidden">
        <div class="roadmap-progress-line w-full h-full bg-gradient-to-b from-[#FF3366] via-secondary to-[#FF9933] origin-top"></div>
      </div>

      <!-- Roadmap items -->
      <div class="space-y-12">
        {milestones.map((item, index) => (
          <div class={`flex items-start ${index % 2 === 1 ? 'md:flex-row-reverse' : 'md:flex-row'} flex-row roadmap-item`}>
            <!-- Content Block -->
            <div class={`w-full md:w-[calc(50%-2.5rem)] ${index % 2 === 0 ? 'md:pr-12 md:text-right' : 'md:pl-12 text-left'} text-left pl-12`}>
              <span class={`inline-block px-3 py-1 rounded-full text-sm font-semibold mb-2 ${
                item.status === 'done' ? 'bg-emerald-950/50 text-emerald-400 border border-emerald-800/30' :
                item.status === 'progress' ? 'bg-amber-950/50 text-amber-400 border border-amber-800/30' :
                item.status === 'bonus' ? 'bg-purple-950/50 text-purple-400 border border-purple-800/30' :
                'bg-navy-800 text-secondary border border-navy-700/50'
              }`}>
                {item.tag}
              </span>
              <h3 class="text-xl font-bold text-white mb-2">{item.title}</h3>
              <p class="text-navy-300 text-sm md:text-base leading-relaxed">{item.description}</p>
            </div>
            
            <!-- Node Marker -->
            <div class="absolute left-0 md:left-1/2 transform md:-translate-x-1/2 mt-1 roadmap-node">
              <div class={`relative z-10 flex items-center justify-center w-10 h-10 rounded-full border-4 border-navy-950 font-bold text-white ${
                item.status === 'done' ? 'bg-gradient-to-r from-emerald-500 to-teal-500' :
                item.status === 'progress' ? 'bg-gradient-to-r from-amber-500 to-orange-500 animate-pulse' :
                item.status === 'bonus' ? 'bg-gradient-to-r from-purple-500 to-indigo-500' :
                'bg-gradient-me'
              }`}>
                <span>{index + 1}</span>
              </div>
            </div>
            
            <!-- Empty Spacer Side -->
            <div class="hidden md:block w-[calc(50%-2.5rem)]"></div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
