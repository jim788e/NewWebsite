---
import Icon from './Icon.astro';
---

<section id="stats" class="relative py-12 bg-navy-950 border-b border-navy-900" aria-label="Live collection statistics">
  <div class="container mx-auto px-4">
    <div id="stats-bar" class="grid grid-cols-1 sm:grid-cols-3 gap-4 max-w-4xl mx-auto">
      <!-- Floor Price -->
      <div class="stat-card flex items-center gap-4 bg-navy-900/60 backdrop-blur-sm border border-navy-800 rounded-2xl p-5">
        <div class="w-10 h-10 rounded-xl bg-gradient-opensea/10 border border-secondary/20 flex items-center justify-center flex-shrink-0">
          <Icon name="gem" class="h-5 w-5 text-secondary" />
        </div>
        <div class="min-w-0">
          <p class="text-navy-400 text-xs uppercase tracking-wider font-semibold mb-1">Floor Price</p>
          <p class="text-white text-lg font-bold font-mono truncate" data-stat="floorPrice">
            <span class="stat-skeleton inline-block h-5 w-16 bg-navy-800 rounded animate-pulse"></span>
          </p>
        </div>
      </div>

      <!-- Total Volume -->
      <div class="stat-card flex items-center gap-4 bg-navy-900/60 backdrop-blur-sm border border-navy-800 rounded-2xl p-5">
        <div class="w-10 h-10 rounded-xl bg-gradient-opensea/10 border border-secondary/20 flex items-center justify-center flex-shrink-0">
          <Icon name="trending-up" class="h-5 w-5 text-secondary" />
        </div>
        <div class="min-w-0">
          <p class="text-navy-400 text-xs uppercase tracking-wider font-semibold mb-1">Total Volume</p>
          <p class="text-white text-lg font-bold font-mono truncate" data-stat="totalVolume">
            <span class="stat-skeleton inline-block h-5 w-16 bg-navy-800 rounded animate-pulse"></span>
          </p>
        </div>
      </div>

      <!-- Holders -->
      <div class="stat-card flex items-center gap-4 bg-navy-900/60 backdrop-blur-sm border border-navy-800 rounded-2xl p-5">
        <div class="w-10 h-10 rounded-xl bg-gradient-opensea/10 border border-secondary/20 flex items-center justify-center flex-shrink-0">
          <Icon name="users" class="h-5 w-5 text-secondary" />
        </div>
        <div class="min-w-0">
          <p class="text-navy-400 text-xs uppercase tracking-wider font-semibold mb-1">Holders</p>
          <p class="text-white text-lg font-bold font-mono truncate" data-stat="numOwners">
            <span class="stat-skeleton inline-block h-5 w-16 bg-navy-800 rounded animate-pulse"></span>
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const formatEth = (value: number | null | undefined): string => {
    if (value === null || value === undefined) {
      return '—';
    }
    return `${value.toFixed(2)} ETH`;
  };

  const formatNumber = (value: number | null | undefined): string => {
    if (value === null || value === undefined) {
      return '—';
    }
    return value.toLocaleString('en-US');
  };

  const handleLoadStats = async (): Promise<void> => {
    const statsBar = document.getElementById('stats-bar');
    const section = statsBar?.closest('section');
    if (!statsBar || !section) {
      return;
    }

    try {
      const res = await fetch('/api/stats.json');
      const data = await res.json();

      if (!res.ok || data.error) {
        section.classList.add('hidden');
        return;
      }

      const floorEl = statsBar.querySelector('[data-stat="floorPrice"]');
      const volumeEl = statsBar.querySelector('[data-stat="totalVolume"]');
      const ownersEl = statsBar.querySelector('[data-stat="numOwners"]');

      if (floorEl) {
        floorEl.textContent = formatEth(data.floorPrice);
      }
      if (volumeEl) {
        volumeEl.textContent = formatEth(data.totalVolume);
      }
      if (ownersEl) {
        ownersEl.textContent = formatNumber(data.numOwners);
      }
    } catch {
      section.classList.add('hidden');
    }
  };

  handleLoadStats();
  document.addEventListener('astro:after-swap', handleLoadStats);
</script>
