---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import Marketplace from '../components/Marketplace.astro';
import Lab from '../components/Lab.astro';
import Synergy from '../components/Synergy.astro';
import Roadmap from '../components/Roadmap.astro';
import Team from '../components/Team.astro';
import Faq from '../components/Faq.astro';
import Cta from '../components/Cta.astro';
import Icon from '../components/Icon.astro';
import logoImg from '../assets/images/logo.webp';
---

<Layout title="MOOZ - NFT Collection | Live on Ethereum | Cool Cows Lab" description="MOOZ is a flagship NFT collection of 1,700 digital cows on Ethereum. Vaults and custom analytics are launching soon on Sei via Cool Cows Lab.">
  <!-- Top decorative scroll progress bar -->
  <div class="fixed top-0 left-0 w-full h-[3px] bg-gradient-to-r from-secondary via-primary to-[#FF9933] z-50 origin-left scale-x-0" id="scroll-progress"></div>

  <div class="flex flex-col min-h-screen bg-navy-950">
    <!-- ETH Migration Complete Banner -->
    <a 
      href="https://x.com/CoolCowsLab/status/2069725634658509222?s=20" 
      target="_blank" 
      rel="noopener noreferrer" 
      class="relative z-50 w-full bg-gradient-to-r from-secondary/20 via-secondary/30 to-secondary/20 border-b border-secondary/30 hover:from-secondary/30 hover:via-secondary/40 hover:to-secondary/30 transition-all duration-300 group"
    >
      <div class="container mx-auto px-4 py-2.5">
        <div class="flex items-center justify-center gap-3 text-sm md:text-base">
          <Icon name="sparkles" class="h-4 w-4 text-secondary animate-pulse" />
          <span class="text-white font-medium">
            <span class="text-secondary font-bold">MOOZ Migration is Complete!</span>
            <span class="text-navy-200 ml-2">Locked at 1,700 supply on Ethereum. Cool Cows Lab is ready on Sei!</span>
          </span>
          <Icon name="arrow-right" class="h-4 w-4 text-secondary group-hover:translate-x-1 transition-transform" />
        </div>
      </div>
      <div class="absolute inset-0 bg-gradient-to-r from-transparent via-secondary/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none"></div>
    </a>

    <!-- Header -->
    <header class="sticky top-0 z-40 w-full bg-navy-950/80 backdrop-blur-sm border-b border-navy-800">
      <div class="container mx-auto px-4 flex h-16 items-center justify-between">
        <div class="flex items-center gap-2">
          <!-- Render logo via optimized Astro Image component -->
          <Image
            src={logoImg}
            alt="MOOZ Logo"
            width={40}
            height={40}
            class="object-contain"
            loading="eager"
          />
        </div>
        
        <!-- Desktop Navigation - Top Right -->
        <nav class="hidden md:flex items-center gap-6">
          <a href="#lab" class="text-white hover:text-secondary transition-colors font-medium">Cool Cows Lab</a>
          <a href="#marketplace" class="text-white hover:text-secondary transition-colors font-medium">Marketplace</a>
          <a href="#roadmap" class="text-white hover:text-secondary transition-colors font-medium">Roadmap</a>
          <a href="#team" class="text-white hover:text-secondary transition-colors font-medium">Team</a>
          <a href="#faq" class="text-white hover:text-secondary transition-colors font-medium">FAQ</a>
        </nav>

        <!-- Mobile Menu Button -->
        <button
          id="mobile-menu-btn"
          class="md:hidden p-2 text-white hover:text-secondary transition-colors"
          aria-label="Toggle menu"
          aria-expanded="false"
        >
          <Icon name="menu" class="h-6 w-6" id="menu-icon" />
          <Icon name="close" class="h-6 w-6 hidden" id="close-icon" />
        </button>
      </div>

      <!-- Mobile Dropdown Menu -->
      <div id="mobile-menu" class="hidden md:hidden border-t border-navy-800 bg-navy-950/95 backdrop-blur-sm">
        <nav class="container mx-auto px-4 py-4 flex flex-col gap-4">
          <a href="#lab" class="mobile-nav-link text-white hover:text-secondary transition-colors py-2 text-lg">Cool Cows Lab</a>
          <a href="#marketplace" class="mobile-nav-link text-white hover:text-secondary transition-colors py-2 text-lg">Marketplace</a>
          <a href="#roadmap" class="mobile-nav-link text-white hover:text-secondary transition-colors py-2 text-lg">Roadmap</a>
          <a href="#team" class="mobile-nav-link text-white hover:text-secondary transition-colors py-2 text-lg">Team</a>
          <a href="#faq" class="mobile-nav-link text-white hover:text-secondary transition-colors py-2 text-lg">FAQ</a>
        </nav>
      </div>
    </header>

    <main id="main-content" class="flex-1">
      <Hero />
      <Marketplace />
      <Lab />
      <Synergy />
      <Roadmap />
      <Team />
      <Faq />
      <Cta />
    </main>
    <Footer />

    <!-- Mobile Sticky CTA -->
    <div id="mobile-sticky-cta" class="fixed bottom-0 left-0 right-0 z-40 p-4 bg-navy-950/95 backdrop-blur-md border-t border-navy-800 md:hidden transform translate-y-full transition-transform duration-300 shadow-[0_-10px_30px_rgba(0,0,0,0.5)]">
      <div class="flex items-center justify-between gap-4">
        <div class="flex items-center gap-2">
          <Image src={logoImg} alt="MOOZ" class="w-8 h-8 object-contain" width={32} height={32} />
          <div>
            <p class="text-white text-xs font-bold font-mono tracking-wider">MOOZ NFT</p>
            <p class="text-navy-300 text-[10px]">Migrated to Ethereum</p>
          </div>
        </div>
        <a
          href="https://opensea.io/collection/mooznfts"
          target="_blank"
          rel="noopener noreferrer"
          class="flex-1 flex items-center justify-center bg-gradient-opensea hover:opacity-90 text-white text-sm py-2.5 px-4 rounded-xl font-semibold gap-2 transition-all shadow-lg"
        >
          <Icon name="opensea" class="h-4 w-4" />
          Buy on OpenSea
        </a>
      </div>
    </div>
  </div>
</Layout>

<script>
  // Wait for DOM to be parsed and window loaded safely
  function initApp() {
    // ----------------------------------------------------
    // 1. Mobile Menu Interactivity
    // ----------------------------------------------------
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const menuIcon = document.getElementById('menu-icon');
    const closeIcon = document.getElementById('close-icon');
    const mobileNavLinks = document.querySelectorAll('.mobile-nav-link');

    if (mobileMenuBtn && mobileMenu && menuIcon && closeIcon) {
      mobileMenuBtn.addEventListener('click', () => {
        const isHidden = mobileMenu.classList.contains('hidden');
        if (isHidden) {
          mobileMenu.classList.remove('hidden');
          menuIcon.classList.add('hidden');
          closeIcon.classList.remove('hidden');
          mobileMenuBtn.setAttribute('aria-expanded', 'true');
        } else {
          mobileMenu.classList.add('hidden');
          menuIcon.classList.remove('hidden');
          closeIcon.classList.add('hidden');
          mobileMenuBtn.setAttribute('aria-expanded', 'false');
        }
      });

      mobileNavLinks.forEach(link => {
        link.addEventListener('click', () => {
          mobileMenu.classList.add('hidden');
          menuIcon.classList.remove('hidden');
          closeIcon.classList.add('hidden');
          mobileMenuBtn.setAttribute('aria-expanded', 'false');
        });
      });
    }

    // ----------------------------------------------------
    // 2. Scroll Progress Indicator
    // ----------------------------------------------------
    const scrollProgress = document.getElementById('scroll-progress');
    window.addEventListener('scroll', () => {
      if (scrollProgress) {
        const scrollTop = window.scrollY;
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        const scrolled = docHeight > 0 ? (scrollTop / docHeight) : 0;
        scrollProgress.style.transform = `scaleX(${scrolled})`;
      }
    });

    // ----------------------------------------------------
    // 3. Mobile Sticky CTA Interactivity (IntersectionObserver)
    // ----------------------------------------------------
    const mobileStickyCta = document.getElementById('mobile-sticky-cta');
    const heroSection = document.querySelector('.hero-section');
    const ctaSection = document.getElementById('cta-section');

    if (mobileStickyCta && heroSection && ctaSection) {
      let heroVisible = true;
      let ctaVisible = false;

      const toggleStickyCta = () => {
        if (!heroVisible && !ctaVisible) {
          mobileStickyCta.classList.remove('translate-y-full');
        } else {
          mobileStickyCta.classList.add('translate-y-full');
        }
      };

      const heroObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          heroVisible = entry.isIntersecting;
          toggleStickyCta();
        });
      }, { threshold: 0.1 });

      const ctaObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          ctaVisible = entry.isIntersecting;
          toggleStickyCta();
        });
      }, { threshold: 0.1 });

      heroObserver.observe(heroSection);
      ctaObserver.observe(ctaSection);
    }

    // ----------------------------------------------------
    // 4. GSAP Scroll Animations
    // ----------------------------------------------------
    // Check user preference for reduced motion before running animations
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (typeof gsap !== 'undefined' && typeof ScrollTrigger !== 'undefined' && !prefersReducedMotion) {
      gsap.registerPlugin(ScrollTrigger);

      // Hero animations
      gsap.from('.hero-bg', {
        scale: 1.15,
        opacity: 0,
        duration: 1.8,
        ease: 'power2.out',
      });

      gsap.from('.hero-word', {
        y: '120%',
        opacity: 0,
        duration: 0.8,
        stagger: 0.08,
        ease: 'power4.out',
      });

      gsap.from('.hero-text', {
        y: 30,
        opacity: 0,
        duration: 1,
        delay: 0.6,
        ease: 'power3.out',
      });

      gsap.from('.hero-cta', {
        scale: 0.9,
        opacity: 0,
        duration: 0.8,
        delay: 0.9,
        ease: 'back.out(1.7)',
      });

      gsap.to('.hero-bg', {
        scrollTrigger: {
          trigger: '.hero-section',
          start: 'top top',
          end: 'bottom top',
          scrub: true,
        },
        y: 120,
        ease: 'none',
      });

      // Marketplace animations
      gsap.from('.marketplace-header', {
        scrollTrigger: {
          trigger: '.marketplace-header',
          start: 'top 85%',
          toggleActions: 'play none none reverse',
        },
        y: 40,
        opacity: 0,
        duration: 0.8,
      });

      gsap.from('.marketplace-tracker', {
        scrollTrigger: {
          trigger: '#marketplace',
          start: 'top 80%',
          toggleActions: 'play none none reverse',
        },
        x: -50,
        opacity: 0,
        duration: 0.8,
        ease: 'power2.out',
      });

      gsap.from('.marketplace-opensea', {
        scrollTrigger: {
          trigger: '#marketplace',
          start: 'top 80%',
          toggleActions: 'play none none reverse',
        },
        x: 50,
        opacity: 0,
        duration: 0.8,
        ease: 'power2.out',
      });

      // Cool Cows Lab Section Animations
      gsap.from('.lab-badge, .lab-header, .lab-desc', {
        scrollTrigger: {
          trigger: '#lab',
          start: 'top 80%',
          toggleActions: 'play none none reverse',
        },
        y: 30,
        opacity: 0,
        duration: 0.8,
        stagger: 0.15,
      });

      gsap.from('.lab-card', {
        scrollTrigger: {
          trigger: '#lab',
          start: 'top 75%',
          toggleActions: 'play none none reverse',
        },
        y: 50,
        opacity: 0,
        duration: 0.8,
        stagger: 0.2,
        ease: 'power3.out',
      });

      gsap.from('.lab-cta', {
        scrollTrigger: {
          trigger: '.lab-cta',
          start: 'top 90%',
          toggleActions: 'play none none reverse',
        },
        scale: 0.9,
        opacity: 0,
        duration: 0.8,
        ease: 'back.out(1.7)',
      });

      // Synergy Section Animations
      gsap.from('.synergy-item', {
        scrollTrigger: {
          trigger: '#synergy',
          start: 'top 85%',
          toggleActions: 'play none none reverse',
        },
        y: -40,
        opacity: 0,
        duration: 0.8,
        ease: 'power2.out',
      });

      gsap.from('.synergy-left-card', {
        scrollTrigger: {
          trigger: '#synergy',
          start: 'top 70%',
          toggleActions: 'play none none reverse',
        },
        x: -80,
        opacity: 0,
        duration: 1,
        ease: 'power3.out',
      });

      gsap.from('.synergy-right-card', {
        scrollTrigger: {
          trigger: '#synergy',
          start: 'top 70%',
          toggleActions: 'play none none reverse',
        },
        x: 80,
        opacity: 0,
        duration: 1,
        ease: 'power3.out',
      });

      gsap.from('.synergy-bottom-card', {
        scrollTrigger: {
          trigger: '.synergy-bottom-card',
          start: 'top 90%',
          toggleActions: 'play none none reverse',
        },
        y: 60,
        opacity: 0,
        duration: 1,
        ease: 'power3.out',
      });

      // Roadmap Progress Line & Nodes
      gsap.set('.roadmap-progress-line', { scaleY: 0 });
      gsap.to('.roadmap-progress-line', {
        scrollTrigger: {
          trigger: '#roadmap-timeline',
          start: 'top 30%',
          end: 'bottom 80%',
          scrub: true,
        },
        scaleY: 1,
        ease: 'none',
      });

      gsap.utils.toArray('.roadmap-node').forEach((node: any) => {
        gsap.from(node, {
          scrollTrigger: {
            trigger: node,
            start: 'top 75%',
            toggleActions: 'play none none reverse',
          },
          scale: 0,
          duration: 0.6,
          ease: 'back.out(2)',
        });
      });

      gsap.utils.toArray('.roadmap-item').forEach((item: any) => {
        gsap.from(item, {
          scrollTrigger: {
            trigger: item,
            start: 'top 85%',
            toggleActions: 'play none none reverse',
          },
          y: 40,
          opacity: 0,
          duration: 0.8,
          ease: 'power2.out',
        });
      });

      // Team Section Animations
      gsap.from('.team-header', {
        scrollTrigger: {
          trigger: '#team',
          start: 'top 85%',
          toggleActions: 'play none none reverse',
        },
        y: 30,
        opacity: 0,
        duration: 0.8,
      });

      gsap.from('.team-card', {
        scrollTrigger: {
          trigger: '#team',
          start: 'top 75%',
          toggleActions: 'play none none reverse',
        },
        y: 40,
        opacity: 0,
        duration: 0.8,
        stagger: 0.2,
      });

      // FAQ Header and Category animations
      gsap.from('.faq-header', {
        scrollTrigger: {
          trigger: '.faq-header',
          start: 'top 85%',
          toggleActions: 'play none none reverse',
        },
        y: 30,
        opacity: 0,
        duration: 0.8,
      });

      gsap.from('.faq-category', {
        scrollTrigger: {
          trigger: '.faq-header',
          start: 'top 80%',
          toggleActions: 'play none none reverse',
        },
        y: 30,
        opacity: 0,
        duration: 0.8,
        stagger: 0.15,
      });

      // Refresh triggers to adjust for image size layout shifts
      window.addEventListener('load', () => ScrollTrigger.refresh());
      setTimeout(() => ScrollTrigger.refresh(), 1000);
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initApp);
  } else {
    initApp();
  }
</script>
