---
import Icon from './Icon.astro';

const faqCategories = [
  {
    title: "Migration to Ethereum",
    icon: "connection" as const,
    subcategories: [
      {
        name: "General Info",
        icon: "question" as const,
        items: [
          {
            id: "faq-mig-1",
            question: "What happened to the migration?",
            answer: "The migration of MOOZ from SEI to Ethereum is officially complete. The SEI collection is fully decommissioned, all migration tickets are closed, and unmigrated NFTs have been absorbed and removed from the collection."
          },
          {
            id: "faq-mig-2",
            question: "What blockchain is MOOZ currently on?",
            answer: "MOOZ now officially lives on Ethereum as our flagship collection. You can purchase MOOZ Cows on OpenSea."
          },
          {
            id: "faq-mig-3",
            question: "What is the final total supply of MOOZ?",
            answer: "The final supply of MOOZ on Ethereum has been permanently locked at 1,700 NFTs. To celebrate this milestone, 30 exclusive MOOZ NFTs were minted and airdropped to random ETH holders."
          }
        ]
      },
      {
        name: "Cool Cows Lab & Sei Ecosystem",
        icon: "connection" as const,
        items: [
          {
            id: "faq-lab-1",
            question: "What is Cool Cows Lab?",
            answer: "Cool Cows Lab is our tools and launchpad hub on Sei. It is designed to incubate top-tier Web3 projects, provide custom analytics/management utilities, and serve as the developer center of our ecosystem."
          },
          {
            id: "faq-lab-2",
            question: "Will I still earn $MOOZ rewards?",
            answer: "Yes! While staking on SEI has decommissioned, Vaults and management tools are relaunching soon on Sei under the Cool Cows Lab ecosystem, powering $MOOZ token utilities."
          }
        ]
      },
      {
        name: "Troubleshooting and Support",
        icon: "x-twitter" as const,
        items: [
          {
            id: "faq-support-1",
            question: "How can I stay updated on Cool Cows Lab and MOOZ roadmap?",
            answer: "Follow our official Twitter account @MoozNft and join our Discord community. We will be sharing details on our next roadmap chapter and tool suite soon."
          }
        ]
      }
    ]
  },
  {
    title: "General Questions",
    icon: "question" as const,
    subcategories: [
      {
        name: "General Details",
        icon: "question" as const,
        items: [
          {
            id: "faq-gen-1",
            question: "What blockchain are MOOZ Cows on?",
            answer: "MOOZ Cows are on the Ethereum blockchain as our flagship collection. Cool Cows Lab tools and launchpad will reside on the SEI blockchain."
          },
          {
            id: "faq-gen-2",
            question: "How many cows are in the collection?",
            answer: "The final total supply of MOOZ Cows on Ethereum is permanently locked at 1,700 NFTs."
          },
          {
            id: "faq-gen-3",
            question: "How do I purchase a MOOZ Cow?",
            answer: "The collection is already fully minted. You can purchase MOOZ Cows on OpenSea."
          },
          {
            id: "faq-gen-4",
            question: "What are the benefits of owning a MOOZ Cow?",
            answer: "Owners get access to exclusive community events, future airdrops, and benefits within the Cool Cows Lab ecosystem (Launchpad, Tools, and Vaults)."
          }
        ]
      }
    ]
  }
];
---

<section id="faq" class="py-20 bg-navy-900 relative overflow-hidden border-t border-navy-950">
  <!-- Background decoration -->
  <div class="absolute inset-0 opacity-5 pointer-events-none">
    <div class="absolute top-1/4 right-0 w-96 h-96 bg-gradient-me rounded-full blur-3xl"></div>
    <div class="absolute bottom-1/4 left-0 w-96 h-96 bg-secondary rounded-full blur-3xl"></div>
  </div>
  
  <div class="container mx-auto px-4 relative z-10">
    <div class="text-center mb-16 faq-header">
      <h2 class="text-4xl md:text-5xl font-bold gradient-text mb-4">Frequently Asked Questions</h2>
      <p class="text-navy-300 text-lg max-w-2xl mx-auto">
        Everything you need to know about MOOZ and the migration to Ethereum
      </p>
    </div>

    <div class="max-w-4xl mx-auto space-y-12">
      {faqCategories.map((category) => (
        <div class="faq-category">
          <div class="flex items-center gap-3 mb-6">
            <Icon name={category.icon} class="h-6 w-6 text-secondary" />
            <h3 class="text-2xl md:text-3xl font-bold text-white">{category.title}</h3>
          </div>
          
          <div class="space-y-6">
            {category.subcategories.map((sub) => (
              <div class="space-y-4">
                {category.subcategories.length > 1 && (
                  <div class="flex items-center gap-2 mb-2 pt-2">
                    <Icon name={sub.icon} class="h-5 w-5 text-secondary" />
                    <h4 class="text-lg font-semibold text-secondary">{sub.name}</h4>
                  </div>
                )}
                
                <div class="space-y-3">
                  {sub.items.map((item) => (
                    <div class="faq-item bg-gradient-to-br from-navy-800 to-navy-800/50 rounded-xl border border-navy-700/50 overflow-hidden transition-all duration-300 hover:border-secondary/50">
                      <button 
                        class="faq-btn w-full px-6 py-4 flex items-center justify-between text-left group"
                        aria-expanded="false"
                        aria-controls={item.id}
                      >
                        <span class="text-white font-semibold pr-4 group-hover:text-secondary transition-colors">{item.question}</span>
                        <!-- Custom styled Chevron icon inside FAQ buttons -->
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5 text-navy-400 flex-shrink-0 transition-transform duration-300"><path d="m6 9 6 6 6-6"/></svg>
                      </button>
                      <div 
                        id={item.id}
                        class="faq-answer max-h-0 opacity-0 overflow-hidden transition-all duration-300"
                        role="region"
                      >
                        <div class="px-6 pb-4 text-navy-300 leading-relaxed">
                          {item.answer}
                        </div>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  function initFaqAccordion() {
    document.querySelectorAll('.faq-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const item = btn.closest('.faq-item');
        const answer = item?.querySelector('.faq-answer') as HTMLElement;
        const icon = btn.querySelector('svg');
        const isExpanded = btn.getAttribute('aria-expanded') === 'true';

        if (!answer) return;

        // Toggle state
        btn.setAttribute('aria-expanded', !isExpanded ? 'true' : 'false');
        
        if (!isExpanded) {
          // Open
          answer.style.maxHeight = answer.scrollHeight + 'px';
          answer.style.opacity = '1';
          icon?.classList.add('rotate-180');
          item?.classList.add('border-secondary/50');
        } else {
          // Close
          answer.style.maxHeight = '0';
          answer.style.opacity = '0';
          icon?.classList.remove('rotate-180');
          item?.classList.remove('border-secondary/50');
        }
      });
    });
  }

  // Load handler
  initFaqAccordion();
  document.addEventListener('astro:after-swap', initFaqAccordion);
</script>
